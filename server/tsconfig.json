{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2022"],
        "module": "nodenext",
        "moduleResolution": "nodenext",

        "rootDir": "src",
        "outDir": "dist",

        "strict": true,
        "skipLibCheck": true,

        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
    },
    "include": ["src"]
}
